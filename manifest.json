<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Polaroid</title>
  <link href="https://fonts.googleapis.com/css2?family=Caveat+Brush&family=Caveat:wght@400;600&display=swap" rel="stylesheet">
  <!-- PWA -->
  <link rel="manifest" href="manifest.json">
  <meta name="theme-color" content="#353535">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Polaroid">
  <link rel="apple-touch-icon" href="icons/icon-192.png">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #353535;
      --surface:   #3e3e3e;
      --border:    rgba(255,255,255,0.18);
      --border-hi: rgba(255,255,255,0.7);
      --text:      #ffffff;
      --text-dim:  rgba(255,255,255,0.45);
      --text-mid:  rgba(255,255,255,0.7);
      --radius:    10px;
      --radius-sm: 6px;
      --font-ui:   'Caveat', cursive;
      --font-hand: 'Caveat Brush', cursive;
    }

    html, body { height: 100%; }

    body {
      min-height: 100dvh;
      background: var(--bg);
      font-family: var(--font-ui);
      font-size: 16px;
      color: var(--text);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0 0 64px;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Status bar ── */
    .status-bar {
      width: 100%;
      height: env(safe-area-inset-top, 12px);
      min-height: 12px;
    }

    /* ── Top nav ── */
    .top-nav {
      width: 100%;
      max-width: 430px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 20px 14px;
    }

    .nav-title {
      font-family: var(--font-hand);
      font-size: 26px;
      letter-spacing: 0.5px;
      color: var(--text);
    }

    .nav-icon-btn {
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      background: none; border: none; cursor: pointer;
      color: var(--text); border-radius: 8px;
      transition: background 0.15s; padding: 0;
    }
    .nav-icon-btn:active { background: rgba(255,255,255,0.08); }

    /* ── Content ── */
    .scroll-content {
      width: 100%; max-width: 430px;
      display: flex; flex-direction: column;
      gap: 12px; padding: 0 16px; flex: 1;
    }

    /* ── Card ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    /* ── Upload zone ── */
    .upload-zone {
      width: 100%;
      display: flex; flex-direction: column; align-items: center;
      padding: 32px 20px 24px;
      text-align: center; gap: 10px;
      transition: border-color 0.2s;
    }
    .upload-zone.drag-over { border-color: var(--border-hi); }

    .upload-icon-wrap {
      width: 64px; height: 64px;
      border: 1px solid var(--border);
      border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 4px;
    }

    .upload-zone h2 {
      font-family: var(--font-hand);
      font-size: 22px; font-weight: 400;
      color: var(--text);
    }

    .upload-zone p {
      font-family: var(--font-ui);
      font-size: 14px; color: var(--text-dim); line-height: 1.5;
    }

    .upload-btn-row {
      display: flex; gap: 10px; width: 100%; margin-top: 8px;
    }

    .pick-btn {
      flex: 1;
      display: flex; align-items: center; justify-content: center; gap: 7px;
      padding: 12px 10px;
      border-radius: var(--radius-sm);
      font-family: var(--font-hand);
      font-size: 18px;
      cursor: pointer; transition: opacity 0.15s; border: none;
    }
    .pick-btn:active { opacity: 0.7; }
    .pick-btn.gallery { background: #ffffff; color: #353535; }
    .pick-btn.camera  { background: transparent; color: var(--text); border: 1px solid var(--border); }

    #fileInputGallery, #fileInputCamera { display: none; }

    /* ── Section label ── */
    .section-label {
      font-family: var(--font-hand);
      font-size: 14px; letter-spacing: 1.2px;
      text-transform: uppercase; color: var(--text-dim);
      padding: 0 4px; margin-top: 4px;
    }

    /* ── Controls ── */
    .controls {
      width: 100%; display: none;
      flex-direction: column; gap: 12px;
    }
    .controls.visible { display: flex; }

    .control-group { display: flex; flex-direction: column; }

    .control-row {
      display: flex; align-items: center;
      padding: 13px 16px; gap: 12px;
      border-bottom: 1px solid var(--border);
    }
    .control-row:last-child { border-bottom: none; }

    .row-icon {
      width: 20px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-mid);
    }

    .row-label {
      font-family: var(--font-hand);
      font-size: 18px; color: var(--text-mid);
      min-width: 80px; flex-shrink: 0;
    }

    .row-input { flex: 1; min-width: 0; }

    .row-input input[type="text"] {
      width: 100%; background: transparent; border: none; outline: none;
      color: var(--text);
      font-family: var(--font-hand);
      font-size: 18px; text-align: right;
    }
    .row-input input[type="text"]::placeholder { color: var(--text-dim); }

    /* ── Sliders ── */
    .slider-wrap {
      display: flex; align-items: center; gap: 10px; flex: 1;
    }

    .slider-wrap input[type="range"] {
      -webkit-appearance: none; appearance: none;
      flex: 1; height: 2px; border-radius: 1px;
      background: var(--border); outline: none; cursor: pointer;
    }
    .slider-wrap input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 18px; height: 18px; border-radius: 50%;
      background: #ffffff; border: none; cursor: pointer;
      box-shadow: 0 1px 4px rgba(0,0,0,0.4);
    }
    .slider-wrap input[type="range"]::-moz-range-thumb {
      width: 18px; height: 18px; border-radius: 50%;
      background: #ffffff; border: none; cursor: pointer;
    }

    .slider-val {
      font-family: var(--font-ui);
      font-size: 14px; color: var(--text-dim);
      min-width: 34px; text-align: right;
      font-variant-numeric: tabular-nums;
    }

    /* ── Filter chips ── */
    .filter-chips {
      display: flex; gap: 8px; padding: 12px 14px;
      overflow-x: auto; scrollbar-width: none;
    }
    .filter-chips::-webkit-scrollbar { display: none; }

    .filter-btn {
      flex-shrink: 0;
      padding: 5px 16px; border-radius: 20px;
      border: 1px solid var(--border);
      background: transparent; color: var(--text-dim);
      font-family: var(--font-hand);
      font-size: 17px;
      cursor: pointer; transition: all 0.15s; white-space: nowrap;
    }
    .filter-btn:active { opacity: 0.7; }
    .filter-btn.active { background: #ffffff; color: #353535; border-color: #ffffff; }

    /* ── Polaroid preview ── */
    .preview-wrap {
      display: none; flex-direction: column; align-items: center; gap: 12px;
    }
    .preview-wrap.visible { display: flex; }

    .polaroid-outer {
      width: 100%; display: flex; justify-content: center; padding: 24px 0 8px;
    }

    .polaroid {
      background: #fefefe;
      padding: 12px 12px 48px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.45);
      position: relative;
      transform: rotate(-1deg);
      transition: transform 0.3s ease;
      width: min(72vw, 280px);
    }
    .polaroid:hover, .polaroid:active { transform: rotate(0deg); }

    .polaroid canvas {
      display: block; width: 100%; height: auto; background: #b0b0b0;
    }

    .polaroid-caption {
      position: absolute;
      bottom: 0; left: 0; right: 0; height: 48px;
      display: flex; align-items: center; justify-content: center; padding: 0 10px;
    }

    .polaroid-caption span {
      font-family: var(--font-hand);
      font-size: 18px; color: #222;
      text-align: center; white-space: nowrap;
      overflow: hidden; text-overflow: ellipsis; max-width: 100%;
    }

    /* ── Action buttons ── */
    .action-stack {
      width: 100%; display: flex; flex-direction: column; gap: 10px;
    }

    .btn-primary {
      width: 100%; background: #ffffff; color: #353535; border: none;
      border-radius: var(--radius-sm);
      font-family: var(--font-hand);
      font-size: 20px;
      padding: 14px; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      transition: opacity 0.15s;
    }
    .btn-primary:active { opacity: 0.75; }
    .btn-primary:disabled { opacity: 0.4; cursor: default; }

    .btn-secondary {
      width: 100%; background: transparent; color: var(--text-mid);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      font-family: var(--font-hand);
      font-size: 18px;
      padding: 12px; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 7px;
      transition: border-color 0.15s, color 0.15s;
    }
    .btn-secondary:active { border-color: var(--border-hi); color: var(--text); }

    /* ── Toast ── */
    #toast {
      position: fixed; bottom: 28px; left: 50%;
      transform: translateX(-50%) translateY(12px);
      background: rgba(255,255,255,0.12);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff;
      font-family: var(--font-ui);
      font-size: 14px;
      padding: 11px 20px; border-radius: 24px;
      white-space: nowrap; opacity: 0;
      transition: opacity 0.25s, transform 0.25s;
      pointer-events: none; z-index: 999;
    }
    #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    #exportCanvas { display: none; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .scroll-content > * { animation: fadeUp 0.3s ease both; }
  </style>
</head>
<body>

  <div class="status-bar"></div>

  <nav class="top-nav">
    <div style="width:36px" id="navSpacer"></div>
    <span class="nav-title">Polaroid</span>
    <button class="nav-icon-btn" id="resetBtn" style="display:none" title="Empezar de nuevo">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
        <path d="M3 3v5h5"/>
      </svg>
    </button>
  </nav>

  <div class="scroll-content">

    <!-- Upload -->
    <div class="card upload-zone" id="uploadZone">
      <div class="upload-icon-wrap">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <path d="m21 15-5-5L5 21"/>
        </svg>
      </div>
      <h2>Elegir foto</h2>
      <p>Selecciona de tu galería o toma una nueva</p>
      <div class="upload-btn-row">
        <button class="pick-btn gallery" id="galleryPickBtn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <path d="m21 15-5-5L5 21"/>
          </svg>
          Galería
        </button>
        <button class="pick-btn camera" id="cameraPickBtn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
          Cámara
        </button>
      </div>
      <input type="file" id="fileInputGallery" accept="image/*">
      <input type="file" id="fileInputCamera"  accept="image/*" capture="environment">
    </div>

    <!-- Polaroid preview -->
    <div class="preview-wrap" id="previewWrap">
      <div class="polaroid-outer">
        <div class="polaroid" id="polaroid">
          <canvas id="photoCanvas"></canvas>
          <div class="polaroid-caption"><span id="captionDisplay"></span></div>
        </div>
      </div>
    </div>

    <!-- Controls -->
    <div class="controls" id="controls">

      <span class="section-label">Ajustar</span>

      <div class="card control-group">

        <!-- Caption -->
        <div class="control-row">
          <div class="row-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 3a2.85 2.85 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
            </svg>
          </div>
          <span class="row-label">Texto</span>
          <div class="row-input">
            <input type="text" id="captionInput" placeholder="Añade nota…" maxlength="30">
          </div>
        </div>

        <!-- Brightness -->
        <div class="control-row">
          <div class="row-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
            </svg>
          </div>
          <span class="row-label">Brillo</span>
          <div class="slider-wrap">
            <input type="range" id="brightnessSlider" min="-100" max="100" value="0" step="1">
            <span class="slider-val" id="brightnessVal">0</span>
          </div>
        </div>

        <!-- Contrast -->
        <div class="control-row">
          <div class="row-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a10 10 0 0 1 0 20z" fill="currentColor" stroke="none" opacity="0.5"/>
            </svg>
          </div>
          <span class="row-label">Contraste</span>
          <div class="slider-wrap">
            <input type="range" id="contrastSlider" min="-100" max="100" value="0" step="1">
            <span class="slider-val" id="contrastVal">0</span>
          </div>
        </div>

        <!-- Grain -->
        <div class="control-row">
          <div class="row-icon">
            <!-- grain / noise icon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="5"  cy="5"  r="1"/><circle cx="12" cy="4"  r="1"/>
              <circle cx="19" cy="5"  r="1"/><circle cx="8"  cy="9"  r="1"/>
              <circle cx="15" cy="9"  r="1"/><circle cx="3"  cy="13" r="1"/>
              <circle cx="10" cy="13" r="1"/><circle cx="18" cy="13" r="1"/>
              <circle cx="6"  cy="18" r="1"/><circle cx="14" cy="17" r="1"/>
              <circle cx="20" cy="19" r="1"/>
            </svg>
          </div>
          <span class="row-label">Grano</span>
          <div class="slider-wrap">
            <input type="range" id="grainSlider" min="0" max="100" value="0" step="1">
            <span class="slider-val" id="grainVal">0</span>
          </div>
        </div>

      </div>

      <span class="section-label">Filtro</span>

      <div class="card">
        <div class="filter-chips" id="filterRow">
          <button class="filter-btn active" data-filter="none">Original</button>
          <button class="filter-btn" data-filter="sepia">Sepia</button>
          <button class="filter-btn" data-filter="bw">B&amp;W</button>
          <button class="filter-btn" data-filter="fade">Faded</button>
          <button class="filter-btn" data-filter="vivid">Vivid</button>
        </div>
      </div>

    </div>

    <!-- Actions -->
    <div class="action-stack" id="actionStack" style="display:none">
      <button class="btn-primary" id="downloadBtn">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Guardar en galería
      </button>
    </div>

  </div>

  <canvas id="exportCanvas"></canvas>
  <div id="toast"></div>

  <script>
    // Register Service Worker for PWA / offline support
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('./sw.js').catch(() => {});
      });
    }
  </script>

  <script>
    const galleryPickBtn   = document.getElementById('galleryPickBtn');
    const cameraPickBtn    = document.getElementById('cameraPickBtn');
    const fileInputGallery = document.getElementById('fileInputGallery');
    const fileInputCamera  = document.getElementById('fileInputCamera');
    const uploadZone       = document.getElementById('uploadZone');
    const controls         = document.getElementById('controls');
    const previewWrap      = document.getElementById('previewWrap');
    const photoCanvas      = document.getElementById('photoCanvas');
    const exportCanvas     = document.getElementById('exportCanvas');
    const captionInput     = document.getElementById('captionInput');
    const captionDisplay   = document.getElementById('captionDisplay');
    const downloadBtn      = document.getElementById('downloadBtn');
    const resetBtn         = document.getElementById('resetBtn');
    const navSpacer        = document.getElementById('navSpacer');
    const actionStack      = document.getElementById('actionStack');
    const filterBtns       = document.querySelectorAll('.filter-btn');
    const brightnessSlider = document.getElementById('brightnessSlider');
    const contrastSlider   = document.getElementById('contrastSlider');
    const grainSlider      = document.getElementById('grainSlider');
    const brightnessVal    = document.getElementById('brightnessVal');
    const contrastVal      = document.getElementById('contrastVal');
    const grainVal         = document.getElementById('grainVal');
    const toast            = document.getElementById('toast');

    let originalImage = null;
    let currentFilter = 'none';
    let brightness    = 0;
    let contrast      = 0;
    let grain         = 0;
    const PHOTO_SIZE  = 800;

    // ── Pickers ──
    galleryPickBtn.addEventListener('click', () => fileInputGallery.click());
    cameraPickBtn.addEventListener('click',  () => fileInputCamera.click());
    fileInputGallery.addEventListener('change', () => { if (fileInputGallery.files[0]) loadImage(fileInputGallery.files[0]); });
    fileInputCamera.addEventListener('change',  () => { if (fileInputCamera.files[0])  loadImage(fileInputCamera.files[0]); });

    uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
    uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
    uploadZone.addEventListener('drop', e => {
      e.preventDefault(); uploadZone.classList.remove('drag-over');
      const file = e.dataTransfer.files[0];
      if (file && file.type.startsWith('image/')) loadImage(file);
    });

    function loadImage(file) {
      const reader = new FileReader();
      reader.onload = ev => {
        const img = new Image();
        img.onload = () => { originalImage = img; showUI(); renderPhoto(); };
        img.src = ev.target.result;
      };
      reader.readAsDataURL(file);
    }

    function showUI() {
      uploadZone.style.display = 'none';
      controls.classList.add('visible');
      previewWrap.classList.add('visible');
      actionStack.style.display = 'flex';
      resetBtn.style.display = 'flex';
      navSpacer.style.display = 'none';
    }

    // ── Sliders ──
    brightnessSlider.addEventListener('input', () => {
      brightness = parseInt(brightnessSlider.value);
      brightnessVal.textContent = brightness > 0 ? '+' + brightness : brightness;
      renderPhoto();
    });

    contrastSlider.addEventListener('input', () => {
      contrast = parseInt(contrastSlider.value);
      contrastVal.textContent = contrast > 0 ? '+' + contrast : contrast;
      renderPhoto();
    });

    grainSlider.addEventListener('input', () => {
      grain = parseInt(grainSlider.value);
      grainVal.textContent = grain;
      renderPhoto();
    });

    // ── Filters ──
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentFilter = btn.dataset.filter;
        renderPhoto();
      });
    });

    // ── Caption ──
    captionInput.addEventListener('input', () => {
      captionDisplay.textContent = captionInput.value.trim();
    });

    // ── Pixel processing ──
    function applyAdjustments(ctx, w, h) {
      const imgData = ctx.getImageData(0, 0, w, h);
      const d = imgData.data;
      const bFactor = brightness * 2.55;
      const cFactor = (259 * (contrast + 255)) / (255 * (259 - contrast));

      for (let i = 0; i < d.length; i += 4) {
        let r = d[i], g = d[i+1], b = d[i+2];

        // Brightness + Contrast
        r += bFactor; g += bFactor; b += bFactor;
        r = cFactor*(r-128)+128;
        g = cFactor*(g-128)+128;
        b = cFactor*(b-128)+128;

        // Color filter
        if (currentFilter === 'sepia') {
          const sr=r*0.393+g*0.769+b*0.189, sg=r*0.349+g*0.686+b*0.168, sb=r*0.272+g*0.534+b*0.131;
          r=sr; g=sg; b=sb;
        } else if (currentFilter === 'bw') {
          r=g=b=r*0.299+g*0.587+b*0.114;
        } else if (currentFilter === 'fade') {
          r=r*0.8+50; g=g*0.8+45; b=b*0.7+40;
        } else if (currentFilter === 'vivid') {
          const avg=(r+g+b)/3;
          r=avg+(r-avg)*1.5; g=avg+(g-avg)*1.5; b=avg+(b-avg)*1.5;
        }

        d[i]  =Math.min(255,Math.max(0,r));
        d[i+1]=Math.min(255,Math.max(0,g));
        d[i+2]=Math.min(255,Math.max(0,b));
      }
      ctx.putImageData(imgData, 0, 0);
    }

    // Grain using canvas noise overlay
    function applyGrain(ctx, w, h, amount) {
      if (amount === 0) return;
      const imgData = ctx.getImageData(0, 0, w, h);
      const d = imgData.data;
      const intensity = amount * 0.55; // scale: 0–55 noise range

      for (let i = 0; i < d.length; i += 4) {
        // Random noise per pixel — monochromatic grain
        const n = (Math.random() * 2 - 1) * intensity;
        d[i]   = Math.min(255, Math.max(0, d[i]   + n));
        d[i+1] = Math.min(255, Math.max(0, d[i+1] + n));
        d[i+2] = Math.min(255, Math.max(0, d[i+2] + n));
      }
      ctx.putImageData(imgData, 0, 0);
    }

    function renderPhoto() {
      if (!originalImage) return;
      const ctx = photoCanvas.getContext('2d');
      photoCanvas.width = PHOTO_SIZE; photoCanvas.height = PHOTO_SIZE;

      const s = originalImage;
      const ratio = Math.max(PHOTO_SIZE/s.width, PHOTO_SIZE/s.height);
      const dw=s.width*ratio, dh=s.height*ratio;
      ctx.drawImage(s, (PHOTO_SIZE-dw)/2, (PHOTO_SIZE-dh)/2, dw, dh);

      if (brightness!==0 || contrast!==0 || currentFilter!=='none') {
        applyAdjustments(ctx, PHOTO_SIZE, PHOTO_SIZE);
      }
      if (grain > 0) {
        applyGrain(ctx, PHOTO_SIZE, PHOTO_SIZE, grain);
      }
    }

    // ── Export canvas ──
    function buildExportCanvas() {
      const PAD=48, BOT=170, TW=PHOTO_SIZE+PAD*2, TH=PHOTO_SIZE+PAD+BOT;
      exportCanvas.width=TW; exportCanvas.height=TH;
      const ctx = exportCanvas.getContext('2d');

      ctx.fillStyle='#fefefe'; ctx.fillRect(0,0,TW,TH);
      ctx.strokeStyle='#e0dbd0'; ctx.lineWidth=3; ctx.strokeRect(1.5,1.5,TW-3,TH-3);

      const g=ctx.createLinearGradient(0,PAD,0,PAD+28);
      g.addColorStop(0,'rgba(0,0,0,0.07)'); g.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=g; ctx.fillRect(PAD,PAD,PHOTO_SIZE,28);

      ctx.drawImage(photoCanvas, PAD, PAD, PHOTO_SIZE, PHOTO_SIZE);

      const caption = captionInput.value.trim();
      if (caption) {
        ctx.fillStyle='#222'; ctx.textAlign='center'; ctx.textBaseline='middle';
        ctx.font=`400 58px 'Caveat Brush', cursive`;
        ctx.fillText(caption, TW/2, PHOTO_SIZE+PAD+BOT/2, TW-60);
      }
    }

    // ── Toast ──
    let toastTimer;
    function showToast(msg) {
      toast.textContent = msg;
      toast.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('show'), 3200);
    }

    // ── Save ──
    const SAVE_ICON = `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`;
    const LOAD_ICON = `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`;

    downloadBtn.addEventListener('click', async () => {
      if (!originalImage) return;
      downloadBtn.disabled = true;
      downloadBtn.innerHTML = `${LOAD_ICON} Procesando…`;
      try {
        buildExportCanvas();
        exportCanvas.toBlob(async (blob) => {
          const fileName = `polaroid-${Date.now()}.png`;
          if (navigator.canShare && navigator.canShare({ files: [new File([blob], fileName, { type:'image/png' })] })) {
            try {
              await navigator.share({ files: [new File([blob], fileName, { type:'image/png' })], title: 'Mi Polaroid' });
              showToast('Guardado — añádelo a la galería desde la hoja de compartir');
            } catch(e) { if (e.name !== 'AbortError') fallbackDownload(blob, fileName); }
          } else { fallbackDownload(blob, fileName); }
          downloadBtn.disabled = false;
          downloadBtn.innerHTML = `${SAVE_ICON} Guardar en galería`;
        }, 'image/png');
      } catch(err) {
        downloadBtn.disabled = false;
        downloadBtn.innerHTML = `${SAVE_ICON} Guardar en galería`;
        showToast('Algo salió mal. Intenta de nuevo.');
      }
    });

    function fallbackDownload(blob, fileName) {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a'); a.href=url; a.download=fileName; a.click();
      URL.revokeObjectURL(url);
      showToast('Descargado — revisa tu carpeta de descargas');
    }

    // ── Reset ──
    resetBtn.addEventListener('click', () => {
      originalImage=null; currentFilter='none'; brightness=0; contrast=0; grain=0;
      brightnessSlider.value=0; contrastSlider.value=0; grainSlider.value=0;
      brightnessVal.textContent='0'; contrastVal.textContent='0'; grainVal.textContent='0';
      captionInput.value=''; captionDisplay.textContent='';
      filterBtns.forEach(b => b.classList.remove('active')); filterBtns[0].classList.add('active');
      fileInputGallery.value=''; fileInputCamera.value='';
      uploadZone.style.display='';
      controls.classList.remove('visible');
      previewWrap.classList.remove('visible');
      actionStack.style.display='none';
      resetBtn.style.display='none';
      navSpacer.style.display='';
    });
  </script>
</body>
</html>
